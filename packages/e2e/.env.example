# Required: Partners API token for the CLI service account
SHOPIFY_CLI_PARTNERS_TOKEN=

# Required: Client ID of the primary test app
SHOPIFY_FLAG_CLIENT_ID=

# Required: Service account email for browser-based OAuth login
E2E_ACCOUNT_EMAIL=

# Required: Service account password for browser-based OAuth login
E2E_ACCOUNT_PASSWORD=

# Optional (Phase 2+): Dev store FQDN for dev server / deploy tests
# E2E_STORE_FQDN=cli-e2e-test.myshopify.com

# Optional (Phase 2+): Client ID of a secondary app for config link tests
# E2E_SECONDARY_CLIENT_ID=
