          "env": "SHOPIFY_FLAG_PASSWORD",
          "hasDynamicHelp": false,
          "multiple": false,
          "name": "password",
          "type": "option"
        },
        "path": {
          "char": "p",
          "default": ".",
          "description": "The path to run tests in. Defaults to current directory.",
          "env": "SHOPIFY_FLAG_PATH",
          "hasDynamicHelp": false,
          "multiple": false,
          "name": "path",
          "type": "option"
        },
        "store": {
          "char": "s",
          "description": "Store URL (overrides environment).",
          "env": "SHOPIFY_FLAG_STORE",
          "hasDynamicHelp": false,
          "multiple": false,
